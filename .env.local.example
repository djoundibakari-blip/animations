# Copier ce fichier en .env.local et remplir les valeurs

# Sécurité JWT (changer en production !)
JWT_SECRET=herald-super-secret-jwt-key-change-this

# LLM Mistral (gratuit sur console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# APIs événements
OPENAGENDA_API_KEY=your_openagenda_api_key_here
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# SMTP pour l'envoi d'e-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=herald@votre-domaine.com

# Neon PostgreSQL — connecter le store dans Vercel > Storage > herald-db > Connect to Project
# Ces variables sont injectées automatiquement par Vercel après connexion du store
# (le nom exact dépend du préfixe choisi lors de la connexion)
DATABASE_URL=your_neon_connection_string_here
# ou STORAGE_URL=... si tu as gardé le préfixe "STORAGE"
