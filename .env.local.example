# Copier ce fichier en .env.local et remplir les valeurs

# Sécurité JWT (changer en production !)
JWT_SECRET=herald-super-secret-jwt-key-change-this

# LLM Mistral (gratuit sur console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# APIs événements
OPENAGENDA_API_KEY=your_openagenda_api_key_here
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# SMTP pour l'envoi d'e-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=herald@votre-domaine.com

# Vercel KV (Redis) — créer le store dans le dashboard Vercel → Storage → KV
# Ces variables sont automatiquement ajoutées quand tu connectes le store au projet
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here
